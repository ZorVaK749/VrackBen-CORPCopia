{
  "family": "task-auth",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::230925194130:role/LabRole",
  "taskRoleArn": "arn:aws:iam::230925194130:role/LabRole",
  "containerDefinitions": [
    {
      "name": "ms-auth-server",
      "image": "230925194130.dkr.ecr.us-east-1.amazonaws.com/vrakben-auth:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8083,
          "hostPort": 8083,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOST",     "value": "10.0.19.92" },
        { "name": "DB_PORT",     "value": "5432" },
        { "name": "DB_NAME",     "value": "vrakben_db" },
        { "name": "DB_USER",     "value": "user_vrakben" },
        { "name": "DB_PASSWORD", "value": "password_vrakben" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/task-auth",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:8083/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
