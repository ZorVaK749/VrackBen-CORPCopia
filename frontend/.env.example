# ============================================================
# VraKBen Frontend Lite — Variables de Entorno
# ============================================================
# Copia este archivo como .env para desarrollo local:
#   cp .env.example .env
#
# IMPORTANTE: Las variables VITE_* se "queman" en el bundle
# durante el build (npm run build). No se pueden cambiar en runtime.
# En producción (ECS), se pasan como --build-arg al docker build.
# ============================================================

# URL del backend ms-catalog Lite.
# Desarrollo local:  http://localhost:8084
# Producción (ECS):  URL del Application Load Balancer del backend
VITE_API_BACKEND_URL=http://localhost:8084
